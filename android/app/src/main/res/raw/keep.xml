<?xml version="1.0" encoding="utf-8"?>
<!-- default_web_client_id is generated by the google-services plugin and read
     only via resources.getIdentifier (LatrApplication), which the resource
     shrinker can't see - without this keep it strips the string and auth is
     disabled in release builds. keep entries are name patterns, so this stays
     harmless when google-services.json (and thus the resource) is absent. -->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@string/default_web_client_id" />
