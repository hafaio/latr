<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Clock hands at 3:02 forming bent-L shape -->
    <!-- Minute hand rotated 12° clockwise (2 min = 12°) -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="12">
        <path
            android:fillColor="@android:color/system_accent1_600"
            android:pathData="M50,28 L58,28 L58,54 L50,54 Z" />
    </group>

    <!-- Hour hand pointing to 3 o'clock -->
    <path
        android:fillColor="@android:color/system_accent1_600"
        android:pathData="M54,50 L70,50 L70,58 L54,58 Z" />

    <!-- Rhombus filling the mitered corner where hands meet -->
    <path
        android:fillColor="@android:color/system_accent1_600"
        android:pathData="M57.91,54.83 L58.94,50 L54,50 L54,58 L49.06,58 L50.09,53.17 Z" />
</vector>
